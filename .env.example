# Copy to `.env` for your own reference; the Flutter app reads these via
# --dart-define (Dart cannot read .env files directly without a plugin), e.g.:
#
# flutter run \
#   --dart-define=SUPABASE_URL=https://xxxxxxxx.supabase.co \
#   --dart-define=SUPABASE_ANON_KEY=eyJxxxxx \
#   --dart-define=GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com

# --- Client (Flutter) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
GOOGLE_CLIENT_ID=

# --- Server (Supabase Edge Function `generate-hairstyle`) ---
# Set with: supabase secrets set REPLICATE_API_TOKEN=...
REPLICATE_API_TOKEN=
REPLICATE_MODEL_VERSION=
# SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY are auto-injected into Edge
# Functions by Supabase and do not need to be set manually.

# Never commit a real .env file with actual keys.
